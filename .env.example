# Phase 0
POSTGRES_PASSWORD=interview_coach
LOG_LEVEL=INFO

# Used by HOST-side runs (pytest, scripts). The api container overrides
# this to use the docker-network hostname `db` (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://interview_coach:interview_coach@localhost:5432/interview_coach

# Phase 1 (auth)
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Phase 3 (Tavily)
TAVILY_API_KEY=

# Phase 5 (LLM) — OpenAI-compatible endpoint
# Compose runs llama as its own service; the api container reaches it as
# http://llama:8080/v1 (set in docker-compose.yml). For HOST-side runs
# (pytest, scripts), keep this at localhost — the llama port is published.
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=
MODEL_NAME=qwen3-8b

# Where the GGUF lives on the host. Defaults to ~/models. The llama service
# bind-mounts this read-only at /models inside the container.
# MODELS_DIR=/path/to/models
# MODEL_FILE=Qwen3-8B-Q4_K_M.gguf

# Phase 10 — LangGraph checkpoint store. In compose this is /data/... on the
# graph_data named volume; for HOST-side runs override to a workspace path
# (or `:memory:` to disable persistence in scripts).
GRAPH_DB_PATH=./data/graph_checkpoints.sqlite

# Phase 11 — Optional Langfuse tracing.
# Set BOTH PUBLIC_KEY and SECRET_KEY to enable per-request tracing of
# LangGraph runs. Leave any unset to disable: the app behaves
# identically to today, with no SDK init, no callback, no network calls.
# HOST defaults to https://cloud.langfuse.com when omitted.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
