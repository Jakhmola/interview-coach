# Phase 0
POSTGRES_PASSWORD=interview_coach
LOG_LEVEL=INFO

# Used by HOST-side runs (pytest, scripts). The api container overrides
# this to use the docker-network hostname `db` (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://interview_coach:interview_coach@localhost:5432/interview_coach

# Phase 1 (auth)
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Phase 3 (Tavily)
TAVILY_API_KEY=

# Phase 5 (LLM) — OpenAI-compatible endpoint (llama.cpp llama-server by default)
# This value is for HOST-side runs (pytest, scripts). The api container
# overrides it to http://host.docker.internal:8080/v1 in docker-compose.yml.
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=
MODEL_NAME=qwen3-8b

# Phase 11 (optional Langfuse)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
